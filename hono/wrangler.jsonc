{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "activity",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-22",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "activity",
      "database_id": "50a077bd-61bd-4638-b2ec-5d7d92df1b17",
    }
  ]
}
